# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# Neon Postgres connection string. Get this from the Vercel "Storage" tab
# (or the Neon dashboard) once you've provisioned the database. Must include
# `?sslmode=require`. The pooled URL is fine for app runtime; drizzle-kit will
# automatically prefer DATABASE_URL_UNPOOLED for migrations if it's set.
DATABASE_URL="postgresql://user:password@ep-xxx-xxx.region.aws.neon.tech/neondb?sslmode=require"

# Optional: direct (non-PgBouncer) connection used by drizzle-kit migrations.
# DATABASE_URL_UNPOOLED="postgresql://user:password@ep-xxx-xxx.region.aws.neon.tech/neondb?sslmode=require"

# ---------------------------------------------------------------------------
# WHOOP integration
# ---------------------------------------------------------------------------
# OAuth client credentials from the WHOOP Developer Dashboard. The client
# secret is also used to verify webhook HMAC-SHA256 signatures.
WHOOP_CLIENT_ID=""
WHOOP_CLIENT_SECRET=""

# Absolute URL the WHOOP authorize page redirects back to. Must EXACTLY
# match a redirect URI registered in the WHOOP dashboard.
#   Local:      http://localhost:3000/auth/whoop/callback
#   Production: https://<your-domain>/auth/whoop/callback
WHOOP_REDIRECT_URI="http://localhost:3000/auth/whoop/callback"

# 32 random bytes, base64-encoded. Used to AES-256-GCM encrypt access/refresh
# tokens at rest. Generate with:  openssl rand -base64 32
# DO NOT change once tokens are stored, or you'll be unable to decrypt them.
WHOOP_TOKEN_ENCRYPTION_KEY=""

# Base URL of this app, used to build absolute redirect URIs. In production
# Vercel sets this for you (or you can rely on the request URL).
APP_URL="http://localhost:3000"

# ---------------------------------------------------------------------------
# Rosewood Rhythm — AI synthesis
# ---------------------------------------------------------------------------
# Anthropic API key for Claude. Without this, the system still renders the
# full demo using curated fallback content, but the arrival brief and daily
# rhythm will not be live-generated.
#
# Get one at: https://console.anthropic.com/
ANTHROPIC_API_KEY=""

# ---------------------------------------------------------------------------
# ElevenLabs (optional, for live voice)
# ---------------------------------------------------------------------------
# Only needed if you re-generate the pre-arrival / post-stay call audio
# server-side. Static MP3s in /public/audio render the demo without this set.
ELEVENLABS_API_KEY=""

# Browser-side: ElevenLabs Conversational AI agent ID. Set this to enable
# the live in-browser voice call ("Place call" button on /control and
# "Talk to Rose" on /user). Create the agent at:
#   https://elevenlabs.io/app/agents
# Recommended system prompt: paste HOUSE_RULES from lib/ai/prompts.ts plus
# the four intake questions. Recommended voice: Charlotte.
NEXT_PUBLIC_ELEVENLABS_AGENT_ID=""

# ---------------------------------------------------------------------------
# Real outbound phone calls (Twilio-via-ElevenLabs)
# ---------------------------------------------------------------------------
# Optional. Set both of these to enable the "Call now" button on /control,
# which dials a real phone via Twilio. The WebRTC browser call works without
# them — use those if you don't want to wire Twilio for the demo.
#
# Setup:
#   1. Buy a Twilio number in your Twilio Console (or reuse one).
#   2. Go to https://elevenlabs.io/app/phone-numbers → Import → Twilio.
#      Paste Twilio Account SID + Auth Token + the E.164 number.
#   3. ElevenLabs returns a phone_number_id (looks like phnum_...).
#   4. Assign that number to your Rose agent in the agent settings.
#   5. Drop both values below and restart the dev server.
ELEVENLABS_PHONE_NUMBER_ID=""
